# blanc-beats configuration
# Copy to .env and fill in values

# Claude API (for description generation)
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_OAUTH_TOKEN_FILE=youtube_token.json

# X / Twitter API v2 (future)
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=

# Pipeline settings
MUSIC_MODEL=ace-step
IMAGE_MODEL=flux
DESCRIPTION_MODEL=claude-sonnet-4-20250514
VARIANTS_PER_RUN=4
TOP_N=1
OUTPUT_DIR=outputs
