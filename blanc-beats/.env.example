# blanc-beats configuration
# Copy to .env and fill in values

# ── Music generation ──────────────────────────────────────────────────
MUSIC_MODEL=ace-step          # ace-step or stub
IMAGE_MODEL=stub              # stub for now (flux later)

# ── Ollama (local LLM for descriptions — Stage 2+) ───────────────────
OLLAMA_MODEL=llama3           # or qwen3.5:8b
OLLAMA_HOST=http://localhost:11434

# ── Pipeline settings ────────────────────────────────────────────────
VARIANTS_PER_RUN=4
TOP_N=1
OUTPUT_DIR=outputs
MODEL_DIR=models
LOG_DIR=logs
LOG_LEVEL=INFO
